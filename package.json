{
  "name": "cms-client",
  "version": "0.1.0",
  "description": "Client SDK for connecting Next.js projects to Better CMS",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "convex": ">=1.0.0",
    "next": ">=16.0.0",
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@better-cms/tsconfig": "workspace:*",
    "@types/react": "^19",
    "convex": "^1.21.0",
    "react": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
